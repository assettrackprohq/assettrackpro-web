# ─────────────────────────────────────────
#  AssetTrackPro Web — .gitignore
# ─────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/

# Environment files — NEVER commit these
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Supabase local config (keep .supabase/ out)
.supabase/

# Vercel
.vercel/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor/IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Temp / cache
.cache/
.parcel-cache/
*.tmp
*.temp
